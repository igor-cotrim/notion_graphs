# Notion public integration (OAuth)
# Create at https://www.notion.so/my-integrations → "Public" integration
# Add http://localhost:3000/api/auth/notion/callback as a redirect URI (and your prod URL)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Neon Postgres — https://neon.tech
DATABASE_URL=

# Signing & encryption keys — generate each with: openssl rand -hex 32
EMBED_SECRET=          # signs /embed/<token> URLs
SESSION_SECRET=        # signs the __session cookie
ENCRYPTION_KEY=        # AES-256-GCM key for Notion tokens stored in the DB

# Public base URL (used to build redirect URIs and minted embed URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
